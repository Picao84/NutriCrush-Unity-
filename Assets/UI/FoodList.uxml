            <ui:Label tabindex="-1" text="Edit Food Deck" parse-escape-sequences="true" display-tooltip-when-elided="true" name="Label" style="-unity-text-align: upper-center; -unity-font-definition: url(&quot;project://database/Assets/Life%20is%20goofy%20SDF%201.asset?fileID=11400000&amp;guid=6cc6927456be1474a82e6b0a18796e5c&amp;type=2#Life is goofy SDF 1&quot;); font-size: 25px; margin-top: 5px; margin-right: 0; margin-bottom: 0; margin-left: 0; height: auto; padding-top: 0; padding-right: 0; padding-bottom: 0; padding-left: 0; align-self: auto; flex-shrink: 0; flex-grow: 0; justify-content: space-around; align-items: stretch; width: 90%; flex-basis: auto; min-width: 90%; max-width: 90%;" />
